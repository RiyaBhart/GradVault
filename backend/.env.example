# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gradvault

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:5173

# JWT — generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
LETTER_ENCRYPTION_KEY=YOUR_FERNET_KEY_HERE

# Supabase Storage (private bucket for photo/video persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_BUCKET=gradvault-media
